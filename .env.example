ODPT_CONSUMER_KEY=your_odpt_key
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy
ODPT_BASE_URL=https://api.odpt.org/api/v4

# 3-letter IATA airport code only
AIRPORT=HKD

# arrivals / departures / both
MODE=both

# Polling interval in seconds
POLL_INTERVAL_SEC=180

# 1 to notify when a flight disappears from the feed
NOTIFY_REMOVED=1

# Optional: Discord Alert Column Numsber (1-10)
DISCORD_ALERT_COLUMN_NUM=3

# Optional: Discord Forum / Media channel thread ID
DISCORD_THREAD_ID=

# State file path
STATE_FILE=data/state.json

# Archive state snapshots with timestamped filenames (for audit logs)
STATE_ARCHIVE=1
STATE_ARCHIVE_DIR=data/state_archive
STATE_ARCHIVE_RETENTION_DAYS=14

# HTTP timeout in seconds
HTTP_TIMEOUT_SEC=30

# 1 = loop forever inside container, 0 = run once and exit
RUN_FOREVER=1

# 1 = post a startup notice to Discord on launch, 0 = disable
STARTUP_NOTICE=1
# Optional: thumbnail image URL for the startup notice embed (e.g. a logo)
STARTUP_LOGO_URL=
